#!/bin/bash

SERVICE_PORT="${TRIM_SERVICE_PORT:-17880}"
ERROR_LOG="${TRIM_TEMP_LOGFILE:-/tmp/pcloud-nas-sync-error.log}"

is_healthy() {
    if command -v curl >/dev/null 2>&1; then
        curl --fail --silent --show-error --max-time 5 "http://127.0.0.1:${SERVICE_PORT}/api/status" >/dev/null 2>&1
        return
    fi
    return 1
}

case "$1" in
start)
    exit 0
    ;;
stop)
    exit 0
    ;;
status)
    if is_healthy; then
        exit 0
    else
        echo "pCloud NAS Sync 未通过本机健康检查，请检查应用任务日志。" > "$ERROR_LOG"
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
